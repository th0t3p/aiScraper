# AI Scraper — Environment Configuration
# Copy to .env and adjust for your environment.

# ── PostgreSQL ────────────────────────────────────────────────────────────
AI_SCRAPER__POSTGRES__HOST=127.0.0.1
AI_SCRAPER__POSTGRES__PORT=5432
AI_SCRAPER__POSTGRES__DATABASE=bugbounty
AI_SCRAPER__POSTGRES__USER=postgres
AI_SCRAPER__POSTGRES__PASSWORD=

# ── Poller ────────────────────────────────────────────────────────────────
AI_SCRAPER__POLLER__MCP_SSE_URL=http://127.0.0.1:9876
AI_SCRAPER__POLLER__POLL_INTERVAL_SECONDS=30
AI_SCRAPER__POLLER__CURSOR_MODE=by_id
# AI_SCRAPER__POLLER__INCLUDE_URL_PATTERNS=["^https://.*\\.example\\.com/.*"]
# AI_SCRAPER__POLLER__AUTHORIZED_SCOPE=["*.example.com","api.target.com"]

# ── API ───────────────────────────────────────────────────────────────────
AI_SCRAPER__API__HOST=127.0.0.1
AI_SCRAPER__API__PORT=8700

# ── General ───────────────────────────────────────────────────────────────
AI_SCRAPER__DEBUG=false
