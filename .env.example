# AI Scraper — Environment Configuration
# Copy to .env and adjust for your environment.
#
# IMPORTANT: Generate a strong password for PostgreSQL:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#   openssl rand -hex 32

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Postgres runs via `docker compose up -d` and listens on 127.0.0.1:5432.
AI_SCRAPER__POSTGRES__HOST=127.0.0.1
AI_SCRAPER__POSTGRES__PORT=5432
AI_SCRAPER__POSTGRES__DATABASE=bugbounty
AI_SCRAPER__POSTGRES__USER=postgres
# REQUIRED: Set a strong password for production deployments
AI_SCRAPER__POSTGRES__PASSWORD=change_me

# ── Poller ────────────────────────────────────────────────────────────────
# Must be genuine 127.0.0.1 — Burp's MCP Server rejects connections whose
# Host/Origin header (or connection origin) isn't real localhost.  This
# cannot work via host.docker.internal or any Docker networking workaround.
AI_SCRAPER__POLLER__MCP_SSE_URL=http://127.0.0.1:9876
AI_SCRAPER__POLLER__POLL_INTERVAL_SECONDS=30
AI_SCRAPER__POLLER__CURSOR_MODE=by_id
# AI_SCRAPER__POLLER__INCLUDE_URL_PATTERNS=["^https://.*\\.example\\.com/.*"]
# AI_SCRAPER__POLLER__AUTHORIZED_SCOPE=["*.example.com","api.target.com"]
# For BurpMCP-Ultra (SSE on / instead of /sse, requires Bearer token):
# AI_SCRAPER__POLLER__MCP_SSE_PATH=/
# AI_SCRAPER__POLLER__MCP_AUTH_TOKEN=<token>

# ── API ───────────────────────────────────────────────────────────────────
AI_SCRAPER__API__HOST=0.0.0.0
AI_SCRAPER__API__PORT=8700
# Set this to enable API authentication. Without it, a WARNING is logged
# but all endpoints are open (convenience for local development).
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# AI_SCRAPER__API__API_KEY=

# ── General ───────────────────────────────────────────────────────────────
AI_SCRAPER__DEBUG=false
